# Copy this file to .env and fill in real values. Never commit .env.

APP_ENV=development
APP_URL=http://localhost/ICALGC_2026/public

# Set to true to disable actual email sending (trial/demo site)
MAIL_DISABLED=false

MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_ENCRYPTION=tls
MAIL_USERNAME=your_gmail@gmail.com
MAIL_PASSWORD=your_16_char_app_password
MAIL_FROM=your_gmail@gmail.com
MAIL_FROM_NAME=ICALGC 2026
